<%-
require 'pathname'

eval(ERB.new(File.read('./partials/slurm_discovery.erb'), trim_mode: '-').result(binding))

partition_options = generate_oc_partition_options(:gpu)
gpu_options = generate_oc_gpu_options
gpu_data = gpu_data_attributes
initial_gpu_max = @global_max_gpus || 1
initial_gpu_label = "Number of GPUs (1 - #{initial_gpu_max})"
default_email = "#{ENV['USER'] || 'user'}@tufts.edu"

if @dynamic_failed || partition_options.nil? || partition_options.empty?
  partition_options = default_gpu_partition_options
  gpu_options = default_gpu_type_options
  initial_gpu_max = 1
  initial_gpu_label = "Number of GPUs (1 - #{initial_gpu_max})"
elsif !partition_options.empty? && !gpu_options.empty?
  initial_partition = partition_options.first[1]
  initial_gpu_type = gpu_options.first[1]
  initial_gpu_max = if @max_gpus_by_partition_and_gpu[initial_partition] &&
                       @max_gpus_by_partition_and_gpu[initial_partition][initial_gpu_type]
                      @max_gpus_by_partition_and_gpu[initial_partition][initial_gpu_type]
                    elsif @max_gpus_by_partition_and_gpu[initial_partition] &&
                          @max_gpus_by_partition_and_gpu[initial_partition]['any']
                      @max_gpus_by_partition_and_gpu[initial_partition]['any']
                    else
                      initial_gpu_max
                    end
  initial_gpu_label = "Number of GPUs (1 - #{initial_gpu_max})"
end

module_root = '/cluster/tufts/apps/container/ngc/modules'

def discover_container_modules(module_root)
  return [] unless Dir.exist?(module_root)

  Dir.glob(File.join(module_root, '**', '*'), File::FNM_DOTMATCH)
     .select { |path| File.file?(path) || File.symlink?(path) }
     .reject do |path|
       rel = Pathname.new(path).relative_path_from(Pathname.new(module_root)).to_s
       parts = rel.split(File::SEPARATOR)
       parts.any? { |part| part.start_with?('.') } || rel.empty?
     end
     .map do |path|
       rel = Pathname.new(path).relative_path_from(Pathname.new(module_root)).to_s
       rel.sub(/\.(lua|tcl)\z/, '')
     end
     .reject { |name| name.empty? || name.end_with?('/default') }
     .uniq
     .sort
end

module_options = discover_container_modules(module_root).map { |name| [name, name] }
-%>
---
form:
  partition:
    widget: select
    label: Partition
<% if !@dynamic_failed -%>
    data:
      partition-gpu-max-cores: '<%= gpu_data[:cores] %>'
      partition-gpu-max-memory: '<%= gpu_data[:memory] %>'
      partition-gpu-max-gpus: '<%= gpu_data[:max_gpus] %>'
      partition-max-hours: '<%= gpu_data[:hours] %>'
      partition-gpu-options: '<%= gpu_data[:gpu_options] %>'
      unavailable-gpus: '<%= gpu_data[:unavailable] %>'
      gres-map: '<%= gpu_data[:gres_map] %>'
<% end -%>
    options:
<% partition_options.each do |opt| -%>
      - <%= to_yaml_flow(opt) %>
<% end -%>

  cores_memory:
    widget: number
    label: [Number of cores, Memory]
    size: 2
    value: [1, 4]

  gpu_type:
    widget: select
    label: GPU Arch
<% if @dynamic_failed -%>
    help: GPU type fallback options are shown because dynamic Slurm discovery is unavailable.
<% else -%>
    help: "Auto-detected GPU types from Slurm. Choose 'any' if you do not have a preference."
<% end -%>
    options:
<% gpu_options.each do |opt| -%>
      - <%= to_yaml_flow(opt) %>
<% end -%>

  gpus:
    widget: number
    label: <%= initial_gpu_label %>
    value: 1
    min: 1
    max: <%= initial_gpu_max %>
    step: 1

  time:
    widget: number
    label: [Max run time hours (0 - 24), Max run minutes (0 - 59)]
    size: 2
    value: [1, 0]
    min: [0, 0]
    max: [24, 59]
    step: [1, 1]

  modules:
    widget: multi_select
    label: Load NGC modules
    separator: " "
    help: |
      Available modules are scanned automatically from `<%= module_root %>` when the form is rendered.
<% if module_options.empty? -%>
    options:
      - ["No modules found under <%= module_root %>", ""]
<% else -%>
    options:
<% module_options.each do |opt| -%>
      - <%= to_yaml_flow(opt) %>
<% end -%>
<% end -%>

  workdir:
    widget: path
    required: false
    label: Working Directory
    help: |
      Optional working directory for the job. If left blank, the job runs from the submission directory.
    favorites:
      - /cluster/tufts
      - /cluster/home

  show_mail_option:
    widget: checkbox
    label:
    options:
      - ["Mail Notifications", "", show-email, show-mail_option ]

  show_array_option:
    widget: checkbox
    label:
    options:
      - ["Array Job", "", show-array ]

  mail_option:
    label: Mail option
    widget: checkbox
    direction: horizontal
    separator: ","
    indent: 1
    options:
      - [ "Beginning of job execution", 'BEGIN',   enable-email ]
      - [ "End of job execution",       'END',     enable-email ]
      - [ "Fail of job",                'FAIL',    enable-email ]
      - [ "When the job is requeued",   'REQUEUE', enable-email ]
      - [ "All",                        'ALL',     enable-email ]

  email:
    widget: email
    label: Email
    value: <%= default_email %>
    indent: 2

  array:
    widget: number
    label: [ Array Job (start index), Array Job (last index) ]
    size: 2
    indent: 1
    min: [0, 0]
    help: Each job executed from an array job is assigned a task ID, which can be referenced via `SLURM_ARRAY_TASK_ID`.

script: |
  #!/bin/bash
  #SBATCH -p #{partition}
  #SBATCH -N 1
  #SBATCH -n #{cores_memory_1}
  #SBATCH --mem #{cores_memory_2}G
  #SBATCH -t #{time_1}:#{time_2}:00
  #SBATCH --array=#{array_1}-#{array_2}
  #SBATCH --gres=gpu:#{:gpu_type_1}#{gpus}
  #{gpu_type_2}
  #SBATCH --mail-user=#{email}
  #SBATCH --mail-type=#{mail_option}
  #SBATCH --error=%x-%J-%u.err
  #SBATCH --output=%x-%J-%u.out

  set -euo pipefail

  if [[ -n "#{workdir}" ]]; then
    cd "#{workdir}"
  else
    cd "${SLURM_SUBMIT_DIR:-$PWD}"
  fi

  module load #{modules}

  export OMP_NUM_THREADS="${SLURM_CPUS_PER_TASK:-#{cores_memory_1}}"

  echo "== Job context =="
  echo "Host: $(hostname)"
  echo "Working directory: $PWD"
  echo "Partition: ${SLURM_JOB_PARTITION:-unknown}"
  echo "Job ID: ${SLURM_JOB_ID:-unknown}"
  echo "Node list: ${SLURM_JOB_NODELIST:-unknown}"
  echo "Visible GPUs: ${CUDA_VISIBLE_DEVICES:-not-set}"
  echo

  echo "== Loaded modules =="
  module list 2>&1 || true
  echo

  if command -v nvidia-smi >/dev/null 2>&1; then
    echo "== NVIDIA GPU inventory =="
    nvidia-smi --query-gpu=index,name,memory.total,driver_version --format=csv
    echo
    echo "== NVIDIA GPU status =="
    nvidia-smi
    echo
  else
    echo "nvidia-smi not found in PATH."
    echo
  fi

  cat <<'EOF'
  Add your NGC workload command below. Typical patterns include:
    apptainer exec --nv <container.sif> <command> [args...]
    python train.py --config <config>
    torchrun --nproc_per_node=${SLURM_GPUS_ON_NODE:-1} train.py
  EOF

check: |
  array_start = @array_1.to_s.strip
  array_end = @array_2.to_s.strip

  if array_start.empty? ^ array_end.empty?
    halt 500, "Both array job start and end must be provided."
  end

  unless array_start.empty?
    halt 500, "Array job start must be greater than 0." if @array_1.to_i <= 0
    halt 500, "Array job end must be greater than 0." if @array_2.to_i <= 0
    halt 500, "Array job end must be greater than or equal to start." if @array_2.to_i < @array_1.to_i
  end

  if @modules.is_a?(Array)
    selected_modules = @modules.reject { |item| item.to_s.strip.empty? }
    halt 500, "Select at least one NGC module." if selected_modules.empty?
  elsif @modules.to_s.strip.empty?
    halt 500, "Select at least one NGC module."
  end
